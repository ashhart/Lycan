;; Interpolate position at arbitrary JD
(F eph_interp (arr jd)
  ($ idx_f (/ (- jd EPH_JD0) EPH_STEP))
  ($ idx (!floor idx_f))
  ($ frac (- idx_f idx))
  (? (< idx 0) (I arr 0)
    (? (>= idx (- EPH_COUNT 1)) (I arr (- EPH_COUNT 1))
      (+ (* (- 1.0 frac) (I arr idx)) (* frac (I arr (+ idx 1)))))))

(F earth_x_at (jd) (eph_interp EARTH_X jd))
(F earth_y_at (jd) (eph_interp EARTH_Y jd))
(F earth_vx_at (jd) (eph_interp EARTH_VX jd))
(F earth_vy_at (jd) (eph_interp EARTH_VY jd))
(F mars_x_at (jd) (eph_interp MARS_X jd))
(F mars_y_at (jd) (eph_interp MARS_Y jd))
(F mars_vx_at (jd) (eph_interp MARS_VX jd))
(F mars_vy_at (jd) (eph_interp MARS_VY jd))
