;; EARTH-TO-MARS MISSION DESIGNER — Adaptive Decision Runtime
;;
;; Uses:
;;   runtime.inputGet  — mission constraints from JSON
;;   !lambert           — Rust-native Lambert solver
;;   stats.*            — result analysis
;;   strategy           — competing search approaches learn over runs
;;
;; Run:
;;   lycan decide demo_mars_decide.lyc --input mars_mission.json

($ PI 3.141592653589793)
($ AU_KM 149597870.7)
($ DAY_S 86400.0)
($ MU 0.0002959122)
($ EPH_N 147)
($ EPH_JD0 2461041.5)
($ EPH_DT 5.0)

;; ── Mission constraints from input (or defaults) ──
($ inp_max_c3 (!cap "runtime.inputGet" "max_c3"))
($ inp_min_tof (!cap "runtime.inputGet" "min_tof"))
($ inp_max_tof (!cap "runtime.inputGet" "max_tof"))
($ inp_window (!cap "runtime.inputGet" "search_window_days"))
($ inp_objective (!cap "runtime.inputGet" "objective"))

($ MAX_C3 (? (!= inp_max_c3 null) inp_max_c3 20.0))
($ MIN_TOF (? (!= inp_min_tof null) inp_min_tof 200.0))
($ MAX_TOF (? (!= inp_max_tof null) inp_max_tof 350.0))
($ WINDOW (? (!= inp_window null) inp_window 700.0))
($ OBJECTIVE (? (!= inp_objective null) inp_objective "c3"))

