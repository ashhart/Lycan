;; ── Interpolation ──
(F interp (arr idx_f)
  ($ i0 (!round (!floor idx_f)))
  ($ frac (- idx_f (!floor idx_f)))
  ($ i1 (+ i0 1))
  (? (< i0 0) (I arr 0)
    (? (>= i0 (- EPH_N 1)) (I arr (- EPH_N 1))
      (+ (* (- 1.0 frac) (I arr i0)) (* frac (I arr i1))))))

(F ex (jd) (interp EX (/ (- jd EPH_JD0) EPH_DT)))
(F ey (jd) (interp EY (/ (- jd EPH_JD0) EPH_DT)))
(F ez (jd) (interp EZ (/ (- jd EPH_JD0) EPH_DT)))
(F evx (jd) (interp EVX (/ (- jd EPH_JD0) EPH_DT)))
(F evy (jd) (interp EVY (/ (- jd EPH_JD0) EPH_DT)))
(F evz (jd) (interp EVZ (/ (- jd EPH_JD0) EPH_DT)))
(F mx (jd) (interp MX (/ (- jd EPH_JD0) EPH_DT)))
(F my (jd) (interp MY (/ (- jd EPH_JD0) EPH_DT)))
(F mz (jd) (interp MZ (/ (- jd EPH_JD0) EPH_DT)))
(F mvx (jd) (interp MVX (/ (- jd EPH_JD0) EPH_DT)))
(F mvy (jd) (interp MVY (/ (- jd EPH_JD0) EPH_DT)))
(F mvz (jd) (interp MVZ (/ (- jd EPH_JD0) EPH_DT)))

;; ── Lambert via Rust native builtin ──
($ MU_AUD 0.0002959122)
($ CONV (/ AU_KM DAY_S))

(F lambert_c3 (jd_dep tof)
  ($ jd_arr (+ jd_dep tof))
  ($ result (!lambert (ex jd_dep) (ey jd_dep) (ez jd_dep)
                      (mx jd_arr) (my jd_arr) (mz jd_arr)
                      tof MU_AUD))
  (? (!= (I result 6) 1.0) 99999.0
    (B
      ($ dvx (- (I result 0) (evx jd_dep)))
      ($ dvy (- (I result 1) (evy jd_dep)))
      ($ dvz (- (I result 2) (evz jd_dep)))
      (* (+ (+ (* dvx dvx) (* dvy dvy)) (* dvz dvz)) (* CONV CONV)))))

(F arr_vinf (jd_dep tof)
  ($ jd_arr (+ jd_dep tof))
  ($ result (!lambert (ex jd_dep) (ey jd_dep) (ez jd_dep)
                      (mx jd_arr) (my jd_arr) (mz jd_arr)
                      tof MU_AUD))
  (? (!= (I result 6) 1.0) 0.0
    (B
      ($ dvx (- (I result 3) (mvx jd_arr)))
      ($ dvy (- (I result 4) (mvy jd_arr)))
      ($ dvz (- (I result 5) (mvz jd_arr)))
      (* (!sqrt (+ (+ (* dvx dvx) (* dvy dvy)) (* dvz dvz))) CONV))))

;; ── PORKCHOP SEARCH — Three strategies compete ──
($ JD0 2461041.5)

;; Strategy 0: Wide coarse sweep (5-day × 10-day, fast)
(F search_coarse (jd0 window min_tof max_tof)
  ($! bc3 99999.0) ($! bjd 0.0) ($! btof 0.0)
  ($! jd jd0)
  (W (< jd (+ jd0 window))
    ($! tof min_tof)
    (W (< tof max_tof)
      ($ c3 (lambert_c3 jd tof))
      (? (&& (> c3 0.5) (< c3 bc3))
        (B (= bc3 c3) (= bjd jd) (= btof tof)) null)
      (= tof (+ tof 10.0)))
    (= jd (+ jd 5.0)))
  (A bc3 bjd btof))

;; Strategy 1: Medium grid (3-day × 5-day)
(F search_medium (jd0 window min_tof max_tof)
  ($! bc3 99999.0) ($! bjd 0.0) ($! btof 0.0)
  ($! jd jd0)
  (W (< jd (+ jd0 window))
    ($! tof min_tof)
    (W (< tof max_tof)
      ($ c3 (lambert_c3 jd tof))
      (? (&& (> c3 0.5) (< c3 bc3))
        (B (= bc3 c3) (= bjd jd) (= btof tof)) null)
      (= tof (+ tof 5.0)))
    (= jd (+ jd 3.0)))
  (A bc3 bjd btof))

;; Strategy 2: Narrow focused (2-day × 3-day, smaller window)
(F search_fine (jd0 window min_tof max_tof)
  ($! bc3 99999.0) ($! bjd 0.0) ($! btof 0.0)
  ($! jd (+ jd0 100.0))
  (W (< jd (+ jd0 (- window 100.0)))
    ($! tof min_tof)
    (W (< tof max_tof)
      ($ c3 (lambert_c3 jd tof))
      (? (&& (> c3 0.5) (< c3 bc3))
        (B (= bc3 c3) (= bjd jd) (= btof tof)) null)
      (= tof (+ tof 3.0)))
    (= jd (+ jd 2.0)))
  (A bc3 bjd btof))

;; Strategy competition — Lycan learns which search finds best C3
($ stage1 (strategy
  (search_coarse JD0 WINDOW MIN_TOF MAX_TOF)
  (search_medium JD0 WINDOW MIN_TOF MAX_TOF)
  (search_fine JD0 WINDOW MIN_TOF MAX_TOF)))

($ s1c3  (I stage1 0))
($ s1jd  (I stage1 1))
($ s1tof (I stage1 2))

;; ── Refinement: 1-day grid around best result ──
($! s2c s1c3) ($! s2j s1jd) ($! s2t s1tof)
($! j2 (- s1jd 10.0))
(W (< j2 (+ s1jd 10.0))
  ($! t2 (- s1tof 15.0))
  (W (< t2 (+ s1tof 15.0))
    ($ c3 (lambert_c3 j2 t2))
    (? (&& (> c3 0.5) (< c3 s2c))
      (B (= s2c c3) (= s2j j2) (= s2t t2)) null)
    (= t2 (+ t2 1.0)))
  (= j2 (+ j2 1.0)))

;; ── Fine pass: 1-hour ──
($! s3c s2c) ($! s3j s2j) ($! s3t s2t)
($! j3 (- s2j 1.5))
(W (< j3 (+ s2j 1.5))
  ($! t3 (- s2t 2.0))
  (W (< t3 (+ s2t 2.0))
    ($ c3 (lambert_c3 j3 t3))
    (? (&& (> c3 0.5) (< c3 s3c))
      (B (= s3c c3) (= s3j j3) (= s3t t3)) null)
    (= t3 (+ t3 0.5)))
  (= j3 (+ j3 0.042)))

;; ── Collect C3 samples for statistical analysis ──
($ c3_samples (A
  (lambert_c3 s3j (- s3t 5.0))
  (lambert_c3 s3j (- s3t 2.0))
  (lambert_c3 s3j s3t)
  (lambert_c3 s3j (+ s3t 2.0))
  (lambert_c3 s3j (+ s3t 5.0))
  (lambert_c3 (- s3j 2.0) s3t)
  (lambert_c3 (+ s3j 2.0) s3t)))
($ c3_mean (!cap "stats.mean" c3_samples))
($ c3_std  (!cap "stats.stdDev" c3_samples))
($ c3_min  (!cap "stats.min" c3_samples))

;; ── Output ──
($ days (- s3j JD0))
($ frac (- days (!floor days)))
($ month (+ 1 (!floor (/ days 30.44))))
($ day (+ 1 (!floor (- days (* (- month 1) 30.44)))))
($ hour (!floor (* frac 24.0)))
($ minute (!round (* (- (* frac 24.0) (!floor (* frac 24.0))) 60.0)))
($ vi_best (arr_vinf s3j s3t))

(!p "================================================================")
(!p " EARTH-TO-MARS — Adaptive Mission Designer")
(!p " JPL DE441 + !lambert + runtime.inputGet + stats.*")
(!p "================================================================")
(!p "")
(!p "  Mission constraints:")
(!p "    max C3:" MAX_C3 "km^2/s^2")
(!p "    TOF range:" MIN_TOF "-" MAX_TOF "days")
(!p "    search window:" WINDOW "days")
(!p "    objective:" OBJECTIVE)
(!p "")
(!p "  Result:")
(!p "    JD:     " s3j)
(!p "    Date:   2026 month" month "day" day)
(!p "    Time:  " hour ":" minute "UTC")
(!p "    TOF:    " (!round s3t) "days")
(!p "    C3:     " (!round (* s3c 100.0)) "/ 100 km^2/s^2")
(!p "    v_inf:  " (!round (* vi_best 10.0)) "/ 10 km/s")
(!p "")
(!p "  Sensitivity (C3 near optimum):")
(!p "    mean:" (!round (* c3_mean 100.0)) "/ 100")
(!p "    std: " (!round (* c3_std 100.0)) "/ 100")
(!p "    min: " (!round (* c3_min 100.0)) "/ 100")
(!p "")
(? (> s3c MAX_C3)
  (!p "  WARNING: Best C3 exceeds constraint (" s3c ">" MAX_C3 ")")
  (!p "  PASS: C3 within constraint"))
(!p "")
(!p "  Reference: Nov-Dec 2026, C3 8-15, TOF 200-300d")
