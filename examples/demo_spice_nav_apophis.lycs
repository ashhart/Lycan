        (third_z mu_neptune neptune_x0 neptune_x1 neptune_y0 neptune_y1 neptune_z0 neptune_z1 x y z t))))

(F j2_x (x y z)
  ($ r (r_norm x y z))
  ($ r2 (+ (+ (* x x) (* y y)) (* z z)))
  ($ s (+ (+ (* x pole_x) (* y pole_y)) (* z pole_z)))
  ($ c (/ (* (* (* 1.5 mu_earth) earth_j2) (* earth_radius earth_radius))
          (* (* r2 r2) r)))
  ($ q (- (* 5.0 (/ (* s s) r2)) 1.0))
  (* c (- (* q x) (* (* 2.0 s) pole_x))))

(F j2_y (x y z)
  ($ r (r_norm x y z))
  ($ r2 (+ (+ (* x x) (* y y)) (* z z)))
  ($ s (+ (+ (* x pole_x) (* y pole_y)) (* z pole_z)))
  ($ c (/ (* (* (* 1.5 mu_earth) earth_j2) (* earth_radius earth_radius))
          (* (* r2 r2) r)))
  ($ q (- (* 5.0 (/ (* s s) r2)) 1.0))
  (* c (- (* q y) (* (* 2.0 s) pole_y))))

(F j2_z (x y z)
  ($ r (r_norm x y z))
  ($ r2 (+ (+ (* x x) (* y y)) (* z z)))
  ($ s (+ (+ (* x pole_x) (* y pole_y)) (* z pole_z)))
  ($ c (/ (* (* (* 1.5 mu_earth) earth_j2) (* earth_radius earth_radius))
          (* (* r2 r2) r)))
  ($ q (- (* 5.0 (/ (* s s) r2)) 1.0))
  (* c (- (* q z) (* (* 2.0 s) pole_z))))

(F accel_x (model x y z t)
  ($ base (central_x x y z))
  ($ ms (? (>= model 1) (+ base (moon_sun_x x y z t)) base))
  ($ pl (? (>= model 2) (+ ms (planets_x x y z t)) ms))
  (? (>= model 3) (+ pl (j2_x x y z)) pl))

(F accel_y (model x y z t)
  ($ base (central_y x y z))
  ($ ms (? (>= model 1) (+ base (moon_sun_y x y z t)) base))
  ($ pl (? (>= model 2) (+ ms (planets_y x y z t)) ms))
  (? (>= model 3) (+ pl (j2_y x y z)) pl))

(F accel_z (model x y z t)
  ($ base (central_z x y z))
  ($ ms (? (>= model 1) (+ base (moon_sun_z x y z t)) base))
  ($ pl (? (>= model 2) (+ ms (planets_z x y z t)) ms))
  (? (>= model 3) (+ pl (j2_z x y z)) pl))

(F rk4_error (model)
  ($! x x0) ($! y y0) ($! z z0)
  ($! vx vx0) ($! vy vy0) ($! vz vz0)
  ($! t 0.0)
  ($! i 0)
  (W (< i steps)
    ($ ax1 (accel_x model x y z t))
    ($ ay1 (accel_y model x y z t))
    ($ az1 (accel_z model x y z t))
    ($ k1x vx) ($ k1y vy) ($ k1z vz)
    ($ k1vx ax1) ($ k1vy ay1) ($ k1vz az1)

    ($ hdt (* 0.5 dt))
    ($ t2 (+ t hdt))
    ($ x2 (+ x (* hdt k1x)))
    ($ y2 (+ y (* hdt k1y)))
    ($ z2 (+ z (* hdt k1z)))
    ($ vx2 (+ vx (* hdt k1vx)))
    ($ vy2 (+ vy (* hdt k1vy)))
    ($ vz2 (+ vz (* hdt k1vz)))
    ($ ax2 (accel_x model x2 y2 z2 t2))
    ($ ay2 (accel_y model x2 y2 z2 t2))
    ($ az2 (accel_z model x2 y2 z2 t2))
    ($ k2x vx2) ($ k2y vy2) ($ k2z vz2)
    ($ k2vx ax2) ($ k2vy ay2) ($ k2vz az2)

    ($ x3 (+ x (* hdt k2x)))
    ($ y3 (+ y (* hdt k2y)))
    ($ z3 (+ z (* hdt k2z)))
    ($ vx3 (+ vx (* hdt k2vx)))
    ($ vy3 (+ vy (* hdt k2vy)))
    ($ vz3 (+ vz (* hdt k2vz)))
    ($ ax3 (accel_x model x3 y3 z3 t2))
    ($ ay3 (accel_y model x3 y3 z3 t2))
    ($ az3 (accel_z model x3 y3 z3 t2))
    ($ k3x vx3) ($ k3y vy3) ($ k3z vz3)
    ($ k3vx ax3) ($ k3vy ay3) ($ k3vz az3)

    ($ t4 (+ t dt))
    ($ x4 (+ x (* dt k3x)))
    ($ y4 (+ y (* dt k3y)))
    ($ z4 (+ z (* dt k3z)))
    ($ vx4 (+ vx (* dt k3vx)))
    ($ vy4 (+ vy (* dt k3vy)))
    ($ vz4 (+ vz (* dt k3vz)))
    ($ ax4 (accel_x model x4 y4 z4 t4))
    ($ ay4 (accel_y model x4 y4 z4 t4))
    ($ az4 (accel_z model x4 y4 z4 t4))
    ($ k4x vx4) ($ k4y vy4) ($ k4z vz4)
    ($ k4vx ax4) ($ k4vy ay4) ($ k4vz az4)

    ($ dt6 (/ dt 6.0))
    (= x (+ x (* dt6 (+ (+ k1x (* 2.0 k2x)) (+ (* 2.0 k3x) k4x)))))
    (= y (+ y (* dt6 (+ (+ k1y (* 2.0 k2y)) (+ (* 2.0 k3y) k4y)))))
    (= z (+ z (* dt6 (+ (+ k1z (* 2.0 k2z)) (+ (* 2.0 k3z) k4z)))))
    (= vx (+ vx (* dt6 (+ (+ k1vx (* 2.0 k2vx)) (+ (* 2.0 k3vx) k4vx)))))
    (= vy (+ vy (* dt6 (+ (+ k1vy (* 2.0 k2vy)) (+ (* 2.0 k3vy) k4vy)))))
    (= vz (+ vz (* dt6 (+ (+ k1vz (* 2.0 k2vz)) (+ (* 2.0 k3vz) k4vz)))))
    (= t (+ t dt))
    (= i (+ i 1)))
  (position_error x y z))


(F rk4_window_error (model sx sy sz svx svy svz start_t window_steps)
  ($! x sx) ($! y sy) ($! z sz)
  ($! vx svx) ($! vy svy) ($! vz svz)
  ($! t start_t)
  ($! i 0)
  (W (< i window_steps)
    ($ ax1 (accel_x model x y z t))
    ($ ay1 (accel_y model x y z t))
    ($ az1 (accel_z model x y z t))
    ($ k1x vx) ($ k1y vy) ($ k1z vz)
    ($ k1vx ax1) ($ k1vy ay1) ($ k1vz az1)

    ($ hdt (* 0.5 dt))
    ($ t2 (+ t hdt))
    ($ x2 (+ x (* hdt k1x)))
    ($ y2 (+ y (* hdt k1y)))
    ($ z2 (+ z (* hdt k1z)))
    ($ vx2 (+ vx (* hdt k1vx)))
    ($ vy2 (+ vy (* hdt k1vy)))
    ($ vz2 (+ vz (* hdt k1vz)))
    ($ ax2 (accel_x model x2 y2 z2 t2))
    ($ ay2 (accel_y model x2 y2 z2 t2))
    ($ az2 (accel_z model x2 y2 z2 t2))
    ($ k2x vx2) ($ k2y vy2) ($ k2z vz2)
    ($ k2vx ax2) ($ k2vy ay2) ($ k2vz az2)

    ($ x3 (+ x (* hdt k2x)))
    ($ y3 (+ y (* hdt k2y)))
    ($ z3 (+ z (* hdt k2z)))
    ($ vx3 (+ vx (* hdt k2vx)))
    ($ vy3 (+ vy (* hdt k2vy)))
    ($ vz3 (+ vz (* hdt k2vz)))
    ($ ax3 (accel_x model x3 y3 z3 t2))
    ($ ay3 (accel_y model x3 y3 z3 t2))
    ($ az3 (accel_z model x3 y3 z3 t2))
    ($ k3x vx3) ($ k3y vy3) ($ k3z vz3)
    ($ k3vx ax3) ($ k3vy ay3) ($ k3vz az3)

    ($ t4 (+ t dt))
    ($ x4 (+ x (* dt k3x)))
    ($ y4 (+ y (* dt k3y)))
    ($ z4 (+ z (* dt k3z)))
    ($ vx4 (+ vx (* dt k3vx)))
    ($ vy4 (+ vy (* dt k3vy)))
    ($ vz4 (+ vz (* dt k3vz)))
    ($ ax4 (accel_x model x4 y4 z4 t4))
    ($ ay4 (accel_y model x4 y4 z4 t4))
    ($ az4 (accel_z model x4 y4 z4 t4))
    ($ k4x vx4) ($ k4y vy4) ($ k4z vz4)
    ($ k4vx ax4) ($ k4vy ay4) ($ k4vz az4)

    ($ dt6 (/ dt 6.0))
    (= x (+ x (* dt6 (+ (+ k1x (* 2.0 k2x)) (+ (* 2.0 k3x) k4x)))))
    (= y (+ y (* dt6 (+ (+ k1y (* 2.0 k2y)) (+ (* 2.0 k3y) k4y)))))
    (= z (+ z (* dt6 (+ (+ k1z (* 2.0 k2z)) (+ (* 2.0 k3z) k4z)))))
    (= vx (+ vx (* dt6 (+ (+ k1vx (* 2.0 k2vx)) (+ (* 2.0 k3vx) k4vx)))))
    (= vy (+ vy (* dt6 (+ (+ k1vy (* 2.0 k2vy)) (+ (* 2.0 k3vy) k4vy)))))
    (= vz (+ vz (* dt6 (+ (+ k1vz (* 2.0 k2vz)) (+ (* 2.0 k3vz) k4vz)))))
    (= t (+ t dt))
    (= i (+ i 1)))
  (position_error x y z))

(F ephemeris_update_error ()
  ($ m (!cap "nav.ephemerisState" ephemeris_path ephemeris_body measurement_et))
  (rk4_window_error 3
    (I m 0) (I m 1) (I m 2)
    (I m 3) (I m 4) (I m 5)
    measurement_t measurement_steps))

(F model_error (model)
  (? (== model 4) (ephemeris_update_error) (rk4_error model)))

(F best_model ()
  ($ e0 (rk4_error 0))
  ($ e1 (rk4_error 1))
  ($ e2 (rk4_error 2))
  ($ e3 (rk4_error 3))
  ($ e4 (ephemeris_update_error))
  (? (&& (< e4 e0) (&& (< e4 e1) (&& (< e4 e2) (< e4 e3))))
    4
    (? (&& (< e3 e0) (&& (< e3 e1) (< e3 e2)))
      3
      (? (&& (< e2 e0) (< e2 e1))
        2
        (? (< e1 e0) 1 0)))))

($ selected_model (choice 0 1 2 3 4))

(!p "=== SPICE-KERNEL OPERATIONAL NAVIGATION: APOPHIS ===")
(!p "target: 99942 Apophis")
(!p "window: 2029-Apr-13 20:01 TDB -> 21:00 TDB")
(!p "reference: Horizons Apophis SPK queried through NAIF/SPICE")
(!p "integrator: RK4 dt=60s, 59 steps + runtime ephemeris update")
(!p "")
(!p "Force model error against SPICE final position:")
(!p "  0 Earth central:                  " (rk4_error 0) "km")
(!p "  1 Earth + Moon + Sun:             " (rk4_error 1) "km")
(!p "  2 + Mercury/Venus/Mars/giants:    " (rk4_error 2) "km")
(!p "  3 + Earth J2:                     " (rk4_error 3) "km")
(!p "  4 + runtime ephemeris update:     " (ephemeris_update_error) "km")
(!p "")
(!p "Best force model by SPICE error:" (best_model))
(!p "AdaptiveChoice selected force model:" selected_model)
(!p "Selected force model error km:" (model_error selected_model))
