           (third_y mu_uranus uranus_x0 uranus_x1 uranus_y0 uranus_y1 uranus_z0 uranus_z1 x y z t))
        (third_y mu_neptune neptune_x0 neptune_x1 neptune_y0 neptune_y1 neptune_z0 neptune_z1 x y z t))))

(F planets_z (x y z t)
