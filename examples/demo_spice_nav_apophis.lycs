(F lerp (a b t)
  (+ a (* (/ t 3600.0) (- b a))))

(F r_norm (x y z)
  (!sqrt (+ (+ (* x x) (* y y)) (* z z))))

(F position_error (x y z)
  ($ dx (- x x_ref))
  ($ dy (- y y_ref))
  ($ dz (- z z_ref))
  (!sqrt (+ (+ (* dx dx) (* dy dy)) (* dz dz))))

(F velocity_error (vx vy vz)
  ($ dx (- vx vx_ref))
  ($ dy (- vy vy_ref))
  ($ dz (- vz vz_ref))
  (!sqrt (+ (+ (* dx dx) (* dy dy)) (* dz dz))))

(F central_x (x y z)
  ($ r (r_norm x y z))
  ($ r3 (* (* r r) r))
  (- 0.0 (/ (* mu_earth x) r3)))

(F central_y (x y z)
  ($ r (r_norm x y z))
  ($ r3 (* (* r r) r))
  (- 0.0 (/ (* mu_earth y) r3)))

(F central_z (x y z)
  ($ r (r_norm x y z))
  ($ r3 (* (* r r) r))
  (- 0.0 (/ (* mu_earth z) r3)))

(F third_x (mu bx0 bx1 by0 by1 bz0 bz1 x y z t)
  ($ bx (lerp bx0 bx1 t))
  ($ by (lerp by0 by1 t))
  ($ bz (lerp bz0 bz1 t))
  ($ dx (- bx x))
  ($ dy (- by y))
  ($ dz (- bz z))
  ($ dr (r_norm dx dy dz))
  ($ br (r_norm bx by bz))
  ($ dr3 (* (* dr dr) dr))
  ($ br3 (* (* br br) br))
  (* mu (- (/ dx dr3) (/ bx br3))))

(F third_y (mu bx0 bx1 by0 by1 bz0 bz1 x y z t)
  ($ bx (lerp bx0 bx1 t))
  ($ by (lerp by0 by1 t))
  ($ bz (lerp bz0 bz1 t))
  ($ dx (- bx x))
  ($ dy (- by y))
  ($ dz (- bz z))
  ($ dr (r_norm dx dy dz))
  ($ br (r_norm bx by bz))
  ($ dr3 (* (* dr dr) dr))
  ($ br3 (* (* br br) br))
  (* mu (- (/ dy dr3) (/ by br3))))

(F third_z (mu bx0 bx1 by0 by1 bz0 bz1 x y z t)
  ($ bx (lerp bx0 bx1 t))
  ($ by (lerp by0 by1 t))
  ($ bz (lerp bz0 bz1 t))
  ($ dx (- bx x))
  ($ dy (- by y))
  ($ dz (- bz z))
  ($ dr (r_norm dx dy dz))
  ($ br (r_norm bx by bz))
  ($ dr3 (* (* dr dr) dr))
  ($ br3 (* (* br br) br))
  (* mu (- (/ dz dr3) (/ bz br3))))

(F moon_sun_x (x y z t)
  (+ (third_x mu_moon moon_x0 moon_x1 moon_y0 moon_y1 moon_z0 moon_z1 x y z t)
     (third_x mu_sun sun_x0 sun_x1 sun_y0 sun_y1 sun_z0 sun_z1 x y z t)))

(F moon_sun_y (x y z t)
  (+ (third_y mu_moon moon_x0 moon_x1 moon_y0 moon_y1 moon_z0 moon_z1 x y z t)
     (third_y mu_sun sun_x0 sun_x1 sun_y0 sun_y1 sun_z0 sun_z1 x y z t)))

(F moon_sun_z (x y z t)
  (+ (third_z mu_moon moon_x0 moon_x1 moon_y0 moon_y1 moon_z0 moon_z1 x y z t)
     (third_z mu_sun sun_x0 sun_x1 sun_y0 sun_y1 sun_z0 sun_z1 x y z t)))

(F planets_x (x y z t)
  (+ (+ (+ (third_x mu_mercury mercury_x0 mercury_x1 mercury_y0 mercury_y1 mercury_z0 mercury_z1 x y z t)
           (third_x mu_venus venus_x0 venus_x1 venus_y0 venus_y1 venus_z0 venus_z1 x y z t))
        (+ (third_x mu_mars mars_x0 mars_x1 mars_y0 mars_y1 mars_z0 mars_z1 x y z t)
           (third_x mu_jupiter jupiter_x0 jupiter_x1 jupiter_y0 jupiter_y1 jupiter_z0 jupiter_z1 x y z t)))
     (+ (+ (third_x mu_saturn saturn_x0 saturn_x1 saturn_y0 saturn_y1 saturn_z0 saturn_z1 x y z t)
           (third_x mu_uranus uranus_x0 uranus_x1 uranus_y0 uranus_y1 uranus_z0 uranus_z1 x y z t))
        (third_x mu_neptune neptune_x0 neptune_x1 neptune_y0 neptune_y1 neptune_z0 neptune_z1 x y z t))))

(F planets_y (x y z t)
